# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies (at all levels)
node_modules
**/node_modules/

# Build files
dist
dist-ssr
*.local
build/

# Environment files (NEVER commit these!)
.env
**/.env
.env.local
.env.development
.env.production

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Documents that shouldn't be in git
*.docx
*.pdf

# Database files (don't commit actual database data)
*.db
*.sqlite
*.sqlite3
/dump/
/data/
/mongodb-data/

# OS files
Thumbs.db
Desktop.ini

# Uploads folder (if it contains user files)
**/uploads/*
!**/uploads/.gitkeep