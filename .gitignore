# Root .gitignore — RUN-WAY/
# ==========================

# NEVER commit node_modules anywhere
node_modules/
**/node_modules/

# NEVER commit package files in root (root is not a Node project)
/package.json
/package-lock.json
/yarn.lock
/pnpm-lock.yaml

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build outputs
dist/
build/
.vercel/

# Environment
.env
.env.local

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# IDE
.vscode/
.idea/